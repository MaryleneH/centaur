{
  "$description": "Centaur design tokens. Monochrome instrument system, two themes. Hex values are exact equivalents of the oklch source authored in CSS.",
  "type": {
    "fontSans": "\"Geist\", ui-sans-serif, system-ui, sans-serif",
    "fontMono": "\"Geist Mono\", ui-monospace, \"SF Mono\", Menlo, monospace",
    "scale": {
      "display": { "size": 64, "weight": 500, "lineHeight": 0.86, "letterSpacing": "-0.03em", "family": "mono", "use": "drift hero number" },
      "verdict": { "size": 21, "weight": 500, "lineHeight": 1.05, "letterSpacing": "0.02em", "family": "mono", "use": "category label on result" },
      "promptLead": { "size": 23, "weight": 400, "lineHeight": 1.32, "letterSpacing": "-0.012em", "family": "sans", "use": "capture question (27 at >=640px)" },
      "taskEcho": { "size": 17, "weight": 400, "lineHeight": 1.5, "letterSpacing": "-0.006em", "family": "sans" },
      "rationale": { "size": 15.5, "weight": 400, "lineHeight": 1.55, "letterSpacing": "-0.005em", "family": "sans" },
      "body": { "size": 14, "weight": 400, "lineHeight": 1.5, "family": "sans" },
      "input": { "size": 16, "weight": 400, "lineHeight": 1.5, "family": "sans", "note": "16px floor prevents iOS zoom-on-focus" },
      "label": { "size": 11, "weight": 500, "lineHeight": 1, "letterSpacing": "0.16em", "textTransform": "uppercase", "family": "mono", "color": "fg-faint" },
      "mono-sm": { "size": 11, "weight": 400, "letterSpacing": "0.04em", "family": "mono" }
    }
  },
  "color": {
    "dark": {
      "bg": "#0d0f10",
      "surface": "#161719",
      "surface-2": "#1d1f20",
      "line": "#2d2f31",
      "line-soft": "#212325",
      "line-strong": "#4b4d4f",
      "fg": "#e8eaeb",
      "fg-dim": "#909294",
      "fg-faint": "#5a5c5e",
      "inv-bg": "#e8eaeb",
      "inv-fg": "#0d0f10"
    },
    "light": {
      "bg": "#f3f4f5",
      "surface": "#fefeff",
      "surface-2": "#ebedef",
      "line": "#d6d8da",
      "line-soft": "#e3e5e7",
      "line-strong": "#aeb1b4",
      "fg": "#191c1e",
      "fg-dim": "#545759",
      "fg-faint": "#87898b",
      "inv-bg": "#191c1e",
      "inv-fg": "#f3f4f5"
    },
    "$note": "No accent hue anywhere. Category meaning is carried by axis position, type weight, and label, never by color."
  },
  "oklch": {
    "$note": "Source of truth. Same channels, lightness varies. chroma <= 0.006, hue 240 (faint cool neutral).",
    "dark": {
      "bg": "oklch(0.165 0.004 240)", "surface": "oklch(0.205 0.004 240)", "surface-2": "oklch(0.238 0.004 240)",
      "line": "oklch(0.305 0.004 240)", "line-soft": "oklch(0.255 0.004 240)", "line-strong": "oklch(0.42 0.004 240)",
      "fg": "oklch(0.935 0.002 240)", "fg-dim": "oklch(0.66 0.004 240)", "fg-faint": "oklch(0.475 0.004 240)"
    },
    "light": {
      "bg": "oklch(0.967 0.002 240)", "surface": "oklch(0.998 0.001 240)", "surface-2": "oklch(0.945 0.003 240)",
      "line": "oklch(0.882 0.004 240)", "line-soft": "oklch(0.922 0.003 240)", "line-strong": "oklch(0.76 0.005 240)",
      "fg": "oklch(0.225 0.006 240)", "fg-dim": "oklch(0.455 0.005 240)", "fg-faint": "oklch(0.63 0.004 240)"
    }
  },
  "space": {
    "$note": "4px base unit. Generous vertical rhythm; negative space is the dominant element.",
    "unit": 4,
    "page-pad": 24, "page-pad-wide": 32,
    "section-gap": 22, "card-pad": 24, "card-pad-y": 28,
    "control-min-height": 56, "tap-target-min": 44
  },
  "radius": { "sm": 2, "md": 3 },
  "layout": { "columnMax": 540, "headerHeight": 52, "breakpointWide": 640, "breakpointNarrow": 380 },
  "motion": {
    "ease": "cubic-bezier(0.2, 0.6, 0.2, 1)",
    "fast": "0.15s", "needleTravel": "0.5s", "viewRise": "0.4s",
    "$note": "Functional only. Motion signals a state change: needle travel on a new reading, a brief reading sweep, a transform-only view rise. No decorative or looping motion. Honor prefers-reduced-motion."
  },
  "axis": {
    "$note": "The signature instrument. One horizontal scale shared by every screen.",
    "stops": [
      { "index": 0, "key": "direct", "label": "Direct", "pct": 0 },
      { "index": 1, "key": "delegate", "label": "Delegate", "pct": 50 },
      { "index": 2, "key": "defer", "label": "Defer", "pct": 100 }
    ],
    "needle": { "width": 2, "height": 22, "fill": "fg", "shape": "vertical line, no fill color", "travel": "left, 0.5s ease" },
    "ghostNeedle": { "width": 1, "height": 14, "fill": "fg-faint", "use": "all-time average behind the recent-average needle" },
    "markerClampPct": [3, 97],
    "indexToPct": "(index / 2) * 100, then clamp to [3,97]"
  }
}
